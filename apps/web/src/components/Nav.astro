---
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const homePrefix = isHome ? '' : '/';

const links = [
  {href: `${homePrefix}#refrigerants`, label: 'Kuldemedier'},
  {href: `${homePrefix}#applications`, label: 'Bruksområder'},
  {href: `${homePrefix}#case`, label: 'Referanser'},
  {href: `${homePrefix}#process`, label: 'Prosess'},
  {href: '/brosjyre', label: 'Brosjyre'},
]

const brandHref = isHome ? '#top' : '/'
const ctaHref = isHome ? '#contact' : '/#contact'
---

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href={brandHref} class="brand" aria-label="Green Circle — by Øen Kuldeteknikk, til toppen">
      <img
        src="/assets/logo.png"
        alt="Green Circle — by Øen Kuldeteknikk"
        class="brand-logo"
        width="4950"
        height="1368"
      />
    </a>

    <div class="nav-links">
      {
        links.map((l) => (
          <a href={l.href} class:list={[{active: pathname === l.href}]}>
            {l.label}
          </a>
        ))
      }
    </div>

    <a href={ctaHref} class="nav-cta">
      Kontakt
      <svg class="arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="M3 8h10m-4-4 4 4-4 4"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
  <div class="progress" id="progress"></div>
</nav>
