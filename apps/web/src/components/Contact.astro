---
const year = new Date().getFullYear();
---

<section id="contact" class="contact">
  <div class="inner">
    <div class="contact-main">
      <h2 class="contact-title reveal">
        La oss<br />bygge noe <span class="lime">bærekraftig.</span>
      </h2>
      <p class="contact-lead reveal">
        Ta kontakt for en uforpliktende samtale om kuldemedium, dimensjonering og leveranse — på telefon,
        e-post eller ved besøk i Hornindal.
      </p>

      <ul class="contact-list reveal" role="list">
        <li class="contact-list-item">
          <span class="contact-label">Adresse</span>
          <div class="contact-body">
            <span>Ytrehornsvegen 58</span>
            <span>6763 Hornindal</span>
          </div>
        </li>
        <li class="contact-list-item">
          <span class="contact-label">Telefon</span>
          <a class="contact-link" href="tel:+4757878400">+47 57 87 84 00</a>
        </li>
        <li class="contact-list-item">
          <span class="contact-label">E-post</span>
          <a class="contact-link" href="mailto:post@kuldeteknikk.com">post@kuldeteknikk.com</a>
        </li>
      </ul>
    </div>

    <div class="foot reveal">
      <div>© {year} ØEN KULDETEKNIKK AS — GREEN CIRCLE</div>
      <div>KVALITET SOM VIKTIGSTE SALGSFAKTOR</div>
    </div>
  </div>
</section>
